# LLM 配置（至少配置一个）
LLM_PROVIDER=deepseek       # 可选: deepseek / openai / qwen / ollama
LLM_API_KEY=sk-your-key-here
LLM_MODEL=deepseek-chat     # deepseek: deepseek-chat | openai: gpt-4o-mini | qwen: qwen-plus | ollama: qwen2.5

# Ollama 本地模型（当 LLM_PROVIDER=ollama 时使用）
OLLAMA_BASE_URL=http://localhost:11434/v1

# 缓存目录（可选，默认 ./data/cache）
CACHE_DIR=./data/cache
